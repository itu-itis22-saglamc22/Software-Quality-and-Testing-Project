Final Test Code (SolutionTest.java)
------------------------------------------------------------

package task18;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

class SolutionTest {

    private final Solution solution = new Solution();

    @Test
    @DisplayName("Smell Test: Null and Empty Guard Clauses")
    void testBoundaryConditions() {
        assertEquals(0, solution.howManyTimes("", "x"));
        assertEquals(0, solution.howManyTimes(null, "x"));
        assertEquals(0, solution.howManyTimes("abc", ""));
    }

    @Test
    @DisplayName("Logic Path: Overlapping and Pattern Detection")
    void testOverlapLogic() {
        // Test Path: Simple match
        assertEquals(1, solution.howManyTimes("john doe", "john"));
        
        // Test Path: Overlapping match (The 'cac' overlap)
        assertEquals(4, solution.howManyTimes("cacacacac", "cac"));
        
        // Test Path: Substring longer than string
        assertEquals(0, solution.howManyTimes("hi", "hello"));
    }
}

