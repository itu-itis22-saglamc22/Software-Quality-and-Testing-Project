Final Test Code (SolutionTest.java)
------------------------------------------------------------

package task13;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;
import java.util.*;

class SolutionTest {

    private final Solution solution = new Solution();

    @Test
    @DisplayName("Smell Test: Empty and Null List Handling")
    void testBoundaryConditions() {
        // Covers the guard branches for empty/null inputs
        assertTrue(solution.longest(null).isEmpty());
        assertTrue(solution.longest(new ArrayList<>()).isEmpty());
    }

    @Test
    @DisplayName("Logic Path: Tie-breaking and Order")
    void testLongestLogic() {
        // Test Path: Standard longest
        List<String> list1 = Arrays.asList("a", "bb", "ccc");
        assertEquals("ccc", solution.longest(list1).get());

        // Test Path: Tie-breaking (Ensures '>' branch is fully tested)
        // If "peach" doesn't replace "apple", the '>' branch false path is covered.
        List<String> list2 = Arrays.asList("apple", "peach", "grape");
        assertEquals("apple", solution.longest(list2).get());
    }
}

