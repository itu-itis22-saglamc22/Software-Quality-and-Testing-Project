Final Test Code (SolutionTest.java)
------------------------------------------------------------

package task11;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

class SolutionTest {

    private final Solution solution = new Solution();

    @Test
    @DisplayName("Smell Test: Null and Empty String Guards")
    void testBoundaryConditions() {
        // Ensures the early return branches are covered
        assertEquals("", solution.makePalindrome(null));
        assertEquals("", solution.makePalindrome(""));
    }

    @Test
    @DisplayName("Logic Path: Input is already a Palindrome")
    void testAlreadyPalindrome() {
        // Covers the case where the loop finds a match immediately
        assertEquals("xyx", solution.makePalindrome("xyx"));
        assertEquals("x", solution.makePalindrome("x"));
    }

    @Test
    @DisplayName("Logic Path: Complex Palindrome Creation")
    void testGeneralCase() {
        // Covers the standard iterative branches of the logic
        assertEquals("xyzyx", solution.makePalindrome("xyz"));
        assertEquals("jerryrrej", solution.makePalindrome("jerry"));
        assertEquals("catac", solution.makePalindrome("cat"));
    }
}

