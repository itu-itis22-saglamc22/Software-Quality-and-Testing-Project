Final Test Code (SolutionTest.java)
------------------------------------------------------------

package task0;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

class SolutionTest {

    private final Solution solution = new Solution();

    @Test
    @DisplayName("Smell Test: Null and Empty Inputs")
    void testBoundaryConditions() {
        assertFalse(solution.hasCloseElements(null, 1.0));
        assertFalse(solution.hasCloseElements(new ArrayList<>(), 1.0));
        assertFalse(solution.hasCloseElements(List.of(5.0), 1.0));
    }

    @Test
    @DisplayName("Logic Check: Valid and Invalid Pairs")
    void testLogicPaths() {
        // Test Path: Positive match
        assertTrue(solution.hasCloseElements(Arrays.asList(1.0, 2.0, 2.05), 0.1));
        
        // Test Path: No match
        assertFalse(solution.hasCloseElements(Arrays.asList(1.0, 5.0, 10.0), 0.5));
        
        // Test Path: Exact threshold (Boundary Smell Check)
        assertFalse(solution.hasCloseElements(Arrays.asList(1.0, 1.3), 0.3));
    }
}

