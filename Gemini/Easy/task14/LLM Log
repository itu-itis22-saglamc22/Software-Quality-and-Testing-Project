Final Test Code (SolutionTest.java)
------------------------------------------------------------

package task14;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;
import java.util.*;

class SolutionTest {

    private final Solution solution = new Solution();

    @Test
    @DisplayName("Smell Test: Null and Empty String Safety")
    void testBoundaryConditions() {
        // Ensures the guard and loop-bypass branches are covered
        assertEquals(List.of(), solution.allPrefixes(null));
        assertEquals(List.of(), solution.allPrefixes(""));
    }

    @Test
    @DisplayName("Logic Path: Prefix Generation Order")
    void testPrefixLogic() {
        // Test Path: Multi-character iteration
        List<String> expected = Arrays.asList("a", "as", "asd", "asdf");
        assertEquals(expected, solution.allPrefixes("asdf"));
        
        // Test Path: Repeated characters
        List<String> expectedWWW = Arrays.asList("W", "WW", "WWW");
        assertEquals(expectedWWW, solution.allPrefixes("WWW"));
    }
}

