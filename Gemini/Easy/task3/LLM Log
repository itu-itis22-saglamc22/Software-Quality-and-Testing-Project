Final Test Code (SolutionTest.java)
------------------------------------------------------------

package task3;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

class SolutionTest {

    private final Solution solution = new Solution();
    private static final double DELTA = 1e-6;

    @Test
    @DisplayName("Smell Test: Floating Point Precision")
    void testFractionalLogic() {
        // Uses delta to avoid the "Brittle Equality" smell
        assertEquals(0.5, solution.truncateNumber(3.5), DELTA);
        assertEquals(0.33, solution.truncateNumber(1.33), DELTA);
        assertEquals(0.456, solution.truncateNumber(123.456), DELTA);
    }

    @Test
    @DisplayName("Logic Path: Whole Numbers and Zero")
    void testBoundaryConditions() {
        // Ensures the result is exactly 0.0 for integers
        assertEquals(0.0, solution.truncateNumber(10.0), DELTA);
        assertEquals(0.0, solution.truncateNumber(0.0), DELTA);
    }
}

