Final Test Code (SolutionTest.java)
------------------------------------------------------------

package task131;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

class SolutionTest {

    private final Solution solution = new Solution();

    @Test
    @DisplayName("Smell Test: Numbers with No Odd Digits")
    void testEvenOnly() {
        // Ensures the 'product never updated' branch is covered
        assertEquals(0, solution.digits(2468));
        assertEquals(0, solution.digits(0));
    }

    @Test
    @DisplayName("Logic Path: Mixed and Odd-only Digits")
    void testOddLogic() {
        // Test Path: Single odd digit
        assertEquals(5, solution.digits(54));
        
        // Test Path: Multiple odd digits (9*7*5)
        assertEquals(315, solution.digits(98765));
        
        // Test Path: 100% odd digits (5*5*7*5*3)
        assertEquals(2625, solution.digits(5576543));
    }
}

