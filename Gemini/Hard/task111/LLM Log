package task111;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;
import java.util.Map;

class SolutionTest {

    private final Solution solution = new Solution();

    @Test
    @DisplayName("Smell Test: Guard clauses for null, empty, and whitespace-only inputs")
    void testBoundaryConditions() {
        // Covers: if (test == null || test.trim().isEmpty())
        assertAll("Boundary Conditions",
            () -> assertTrue(solution.histogram(null).isEmpty(), "Null should return empty map"),
            () -> assertTrue(solution.histogram("").isEmpty(), "Empty string should return empty map"),
            () -> assertTrue(solution.histogram("   ").isEmpty(), "Whitespace-only should return empty map")
        );
    }

    @Test
    @DisplayName("Logic Path: Handle extra consecutive spaces")
    void testExtraSpaces() {
        // Covers: if (s.isEmpty()) continue; 
        // split(" ") on "a  b" creates an array ["a", "", "b"]
        assertEquals(Map.of("a", 1, "b", 1), solution.histogram("a  b"));
    }

    @Test
    @DisplayName("Logic Path: Filter lower frequencies out")
    void testSingleMaximum() {
        // Covers: if (entry.getValue() == maxCount) -> False path for 'b'
        assertEquals(Map.of("a", 2), solution.histogram("a a b"));
    }

    @Test
    @DisplayName("Logic Path: Tied maximums without exceeding maxCount")
    void testTiedMaximums() {
        // Covers: if (currentCount > maxCount) -> False path
        // When second 'a' is read, currentCount=2, maxCount=2. It skips the if-block.
        assertEquals(Map.of("a", 2, "b", 2), solution.histogram("a b b a"));
    }
}

